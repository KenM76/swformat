# SWFormat .gitignore — also enforces corpus IP rules.

# Python build/cache
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
dist/
build/
*.egg
.installed.cfg

# Virtual environments
.venv/
venv/
env/
.env

# IDEs / editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Test artifacts
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Local scratch + tmp
tmp/
scratch/
*.tmp

# === CORPUS IP RULES ===
# Real SOLIDWORKS files MUST NOT be committed.
# Only synthetic files generated by tools/corpus_gen/ may live in test/corpus/
# Owner files are referenced by absolute path in test/corpus/corpus.config.json.

# Block all SW files by default
*.SLDPRT
*.sldprt
*.SLDASM
*.sldasm
*.SLDDRW
*.slddrw
*.SLDLFP
*.sldlfp
*.PRTDOT
*.prtdot
*.ASMDOT
*.asmdot
*.DRWDOT
*.drwdot

# Whitelist synthetic corpus generated by tools/corpus_gen/
# (this requires explicit !test/corpus/<...> entries below as those files are added)
# Example: !test/corpus/parts/2026/cube_100mm_one_extrude.sldprt

# Auto-recovery / backup files
*.swar
*.bak
Backup_of_*

# === INTERNAL-ONLY TREES (excluded from the public library) ===
# Reverse-engineering scratch (hypothesis logs, probe scripts, .csx corpus
# generators that drive the SOLIDWORKS API) and Claude Code agent infra
# (definitions + memory) are kept local and NEVER published: they reference
# environment-specific paths and non-synthetic corpus files. The reusable
# library lives entirely under src/, test/, and docs/.
research/empirical_findings/
.claude/
# Belt-and-braces: never publish SOLIDWORKS-API automation scripts.
*.csx

# Logs
*.log
logs/
